---
name: "Deploy to Server"

on:
  push:
    branches: [main]

jobs:
  trigger-deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Trigger IAC deployment
        uses: peter-evans/repository-dispatch@v3
        with:
          token: ${{ secrets.IAC_REPO_PAT }}
          repository: Block-Farms/Standard-Template-Construct-IAC
          event-type: deploy-shopify-storefront
          client-payload: '{"git_ref": "${{ github.sha }}"}'
