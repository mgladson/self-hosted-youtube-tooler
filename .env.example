# ============================================
# Shopify Stack Clone — Environment Variables
# ============================================
# Copy this file to .env and fill in values.
# DO NOT commit .env to version control.

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shopify_stack
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_POOL_CONNECT_TIMEOUT=5000

# ---- Valkey (Redis-compatible) ----
VALKEY_HOST=valkey
VALKEY_PORT=6379
# Required in production — must be non-trivial (not "password", "valkey", etc.)
VALKEY_PASSWORD=
VALKEY_URL=redis://${VALKEY_HOST}:${VALKEY_PORT}

# ---- MinIO (S3-compatible) ----
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=
MINIO_USE_SSL=false
MINIO_BUCKET_FILES=product-files
MINIO_BUCKET_IMAGES=product-images

# ---- Image serving ----
# Public URL base for uploaded images (testimonials, recipes). The app appends
# the object key, e.g. <base>/testimonials/<uuid>.jpg. The bundled docker/Caddyfile
# maps /images/* -> MinIO, so the default works as-is for local dev. A deployment
# whose proxy exposes the bucket on a different path overrides this (e.g. the
# Ansible IAC serves it at /cdn and sets IMAGE_PUBLIC_BASE=/cdn).
IMAGE_PUBLIC_BASE=/images

# ---- Mailpit (dev email) ----
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ---- API Server ----
API_HOST=0.0.0.0
API_PORT=3001
NODE_ENV=development
SITE_URL=http://localhost

# ---- Metrics (Prometheus exposition) ----
# Dedicated http.Server in the api process, no app-layer auth.
# Network-layer security only: UFW restricts the port to the monitoring host.
METRICS_PORT=9091
METRICS_LISTEN_ADDR=0.0.0.0

# ---- Storefront (Next.js) ----
STOREFRONT_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_SITE_URL=http://localhost
API_INTERNAL_URL=http://api:3001

# ---- Admin (Vite React) ----
ADMIN_PORT=3002
VITE_API_URL=http://localhost/api

# ---- Docs (Next.js) ----
DOCS_PORT=3003

# ---- Caddy ----
CADDY_PORT=80

# ---- SMTP ----
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=PixelCart <noreply@pixelcart.com>

# ---- Auth (Google OAuth) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost/api/auth/google/callback
SESSION_SECRET=

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
# For local dev: run `stripe listen --forward-to localhost:3001/api/checkout/webhook`
# and use the webhook signing secret it prints.
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Set to true once you have added tax registrations in Stripe Dashboard.
STRIPE_TAX_ENABLED=false

# ---- App ----
BASE_URL=http://localhost
# Set to "true" ONLY in development — enables dev login bypass (requires NODE_ENV=development too)
ENABLE_DEV_FEATURES=false

# ---- GeoIP (optional — enables country column in security dashboard) ----
# 1. Free account at maxmind.com → My Account → Manage License Keys
# 2. Download GeoLite2-Country.mmdb and place it at the project root
# MAXMIND_LICENSE_KEY=  # not consumed by the app — used only for manual download script
